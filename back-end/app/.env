MONGO_URI=mongodb://localhost:27017/
DB_NAME=feelFrame

# -------------------------------------------------------------------
# Autenticação JWT
# -------------------------------------------------------------------
# Gere uma chave forte em produção: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-strong-random-key-in-production
JWT_EXPIRE_HOURS=168

# -------------------------------------------------------------------
# Google OAuth (obtenha em: https://console.cloud.google.com/apis/credentials)
# -------------------------------------------------------------------
GOOGLE_CLIENT_ID=
VIDEO_UPLOAD_SUBFOLDER=videos_originais
FRAME_ANALYSIS_SKIP_RATE=4
FIREBASE_CREDENTIALS_PATH=app/credentials/serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=feelframe-2b682.firebasestorage.app

# -------------------------------------------------------------------
# Storage: escolha o backend de armazenamento
#   firebase  → Firebase Storage (produção, padrão)
#   local     → disco local (desenvolvimento / testes offline)
# -------------------------------------------------------------------
STORAGE_BACKEND=firebase

# Caminho base para o LocalStorageService (só usado quando STORAGE_BACKEND=local)
# Deixe em branco para usar o padrão: ~/FeelFrameLocalStorage
LOCAL_STORAGE_PATH=

# -------------------------------------------------------------------
# Processamento de vídeo
# -------------------------------------------------------------------
# Número de workers CPU para o ThreadPoolExecutor do VideoService (padrão: 2)
VIDEO_POOL_WORKERS=2

# Dimensões do frame de saída processado (padrão: 480x480)
OUTPUT_WIDTH=480
OUTPUT_HEIGHT=480

# Nome da subpasta onde os vídeos com quadro fixo são salvos (padrão: videos_quadro_fixo)
FIXED_FRAME_VIDEOS_DIR=videos_quadro_fixo